<script>
function tog(btn) {
  btn.classList.toggle('open');
  const ex = btn.nextElementSibling;
  ex.classList.toggle('open');
  const ch = btn.querySelector('.ch');
  ch.style.transform = btn.classList.contains('open') ? 'rotate(90deg)' : 'rotate(0)';
  btn.lastChild.textContent = btn.classList.contains('open') ? ' ver menos' : ' ver mais';
}

function fAll(btn) {
  document.querySelectorAll('.entry').forEach(e => e.classList.remove('hidden'));
  document.querySelectorAll('.fbtn').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
}

function fCat(cat, btn) {
  document.querySelectorAll('.entry').forEach(e => {
    const c = e.dataset.cat || '';
    e.classList.toggle('hidden', !c.includes(cat));
  });
  document.querySelectorAll('.fbtn').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
}
</script>
