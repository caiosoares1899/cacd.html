<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Arte no Brasil — Linha do Tempo Completa</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0D0B08;
  --bg2: #141209;
  --bg3: #1C1810;
  --bg4: #231E14;
  --surface: #1A1610;
  --surface2: #221D13;
  --border: rgba(255,220,100,0.08);
  --border2: rgba(255,220,100,0.15);
  --gold: #C9A84C;
  --gold2: #E8C97A;
  --gold-dim: rgba(201,168,76,0.35);
  --cream: #F2EAD8;
  --cream2: #C8BFA8;
  --cream3: #8A8070;
  --line: rgba(201,168,76,0.2);

  --red:    #C0392B; --red-dim:    rgba(192,57,43,0.15);
  --amber:  #C67C2A; --amber-dim:  rgba(198,124,42,0.15);
  --green:  #2A7A4A; --green-dim:  rgba(42,122,74,0.15);
  --blue:   #1A5FA0; --blue-dim:   rgba(26,95,160,0.15);
  --purple: #6B2FA0; --purple-dim: rgba(107,47,160,0.15);
  --teal:   #1A7A7A; --teal-dim:   rgba(26,122,122,0.15);
  --rose:   #A03060; --rose-dim:   rgba(160,48,96,0.15);
  --ochre:  #8A6A1A; --ochre-dim:  rgba(138,106,26,0.15);
}

*{margin:0;padding:0;box-sizing:border-box}

body {
  background: var(--bg);
  color: var(--cream);
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  line-height: 1.7;
  min-height: 100vh;
}

/* ── HEADER ── */
header {
  background: var(--bg2);
  border-bottom: 1px solid var(--border2);
  padding: 72px 56px 56px;
  position: relative;
  overflow: hidden;
}
header::before {
  content:'';
  position:absolute; top:-120px; right:-80px;
  width:500px; height:500px;
  border-radius:50%;
  background: radial-gradient(circle, rgba(201,168,76,0.06) 0%, transparent 70%);
  pointer-events:none;
}
header::after {
  content:'';
  position:absolute; bottom:-100px; left:15%;
  width:350px; height:350px;
  border-radius:50%;
  background: radial-gradient(circle, rgba(201,168,76,0.04) 0%, transparent 70%);
  pointer-events:none;
}
.header-eyebrow {
  font-family:'DM Mono',monospace;
  font-size:10px; letter-spacing:3px;
  text-transform:uppercase;
  color: var(--gold);
  margin-bottom:18px;
  opacity:.8;
}
header h1 {
  font-family:'Cormorant Garamond',serif;
  font-size: clamp(42px,6vw,88px);
  font-weight:300;
  line-height:1.0;
  letter-spacing:-1px;
  color: var(--cream);
}
header h1 em {
  font-style:italic;
  color: var(--gold2);
}
.header-sub {
  margin-top:22px;
  font-size:14px;
  color: var(--cream3);
  max-width:560px;
  font-weight:300;
  line-height:1.8;
}
.header-stats {
  display:flex; gap:48px; flex-wrap:wrap;
  margin-top:48px;
  padding-top:36px;
  border-top:1px solid var(--border);
}
.stat { display:flex; flex-direction:column; gap:4px; }
.stat-n {
  font-family:'Cormorant Garamond',serif;
  font-size:36px; font-weight:300;
  color: var(--gold2);
  line-height:1;
}
.stat-d {
  font-family:'DM Mono',monospace;
  font-size:10px; letter-spacing:1.5px;
  text-transform:uppercase;
  color: var(--cream3);
}

/* ── FILTERS ── */
.filters-bar {
  background: var(--bg2);
  border-bottom:1px solid var(--border);
  padding:0 56px;
  display:flex; gap:0;
  overflow-x:auto;
  scrollbar-width:none;
  position:sticky; top:0; z-index:100;
}
.filters-bar::-webkit-scrollbar{display:none}
.fbtn {
  padding:14px 22px;
  font-family:'DM Mono',monospace;
  font-size:10px; letter-spacing:1.5px;
  text-transform:uppercase;
  color: var(--cream3);
  background:none; border:none;
  border-bottom:2px solid transparent;
  cursor:pointer; white-space:nowrap;
  transition:all .2s;
}
.fbtn:hover { color:var(--cream2); }
.fbtn.on { color:var(--gold); border-bottom-color:var(--gold); }

/* category dot on filter */
.fbtn .fdot {
  display:inline-block;
  width:6px; height:6px; border-radius:50%;
  margin-right:6px; vertical-align:middle;
}

/* ── LEGEND ── */
.legend {
  background: var(--bg2);
  border-bottom:1px solid var(--border);
  padding:14px 56px;
  display:flex; gap:16px; flex-wrap:wrap; align-items:center;
}
.legend-label {
  font-family:'DM Mono',monospace;
  font-size:9px; letter-spacing:2px;
  text-transform:uppercase;
  color:var(--cream3);
  margin-right:4px;
}
.ltag {
  display:inline-flex; align-items:center; gap:5px;
  font-size:10px; font-family:'DM Mono',monospace;
  padding:2px 8px; border-radius:2px;
  letter-spacing:.5px;
}

/* ── TIMELINE WRAP ── */
.tl {
  max-width:1120px;
  margin:0 auto;
  padding:80px 56px 100px;
  position:relative;
}
.tl::before {
  content:'';
  position:absolute;
  left:50%;
  top:0; bottom:0;
  width:1px;
  background: linear-gradient(to bottom, transparent, var(--line) 4%, var(--line) 96%, transparent);
  transform:translateX(-50%);
}

/* ── ERA DIVIDER ── */
.era {
  text-align:center;
  margin:72px 0 48px;
  position:relative;
  z-index:2;
}
.era-inner {
  display:inline-flex; align-items:center; gap:16px;
  background: var(--bg3);
  border:1px solid var(--border2);
  padding:8px 24px 8px 20px;
}
.era-num {
  font-family:'Cormorant Garamond',serif;
  font-size:28px; font-weight:300; font-style:italic;
  color: var(--gold);
  line-height:1;
}
.era-name {
  font-family:'DM Mono',monospace;
  font-size:10px; letter-spacing:2px;
  text-transform:uppercase;
  color: var(--cream3);
}

/* ── ENTRY ── */
.entry {
  display:grid;
  grid-template-columns:1fr 64px 1fr;
  margin-bottom:56px;
  position:relative;
}
.entry.feat { margin-bottom:80px; }
.entry.left  .ca { grid-column:1; }
.entry.left  .dc { grid-column:2; }
.entry.left  .em { grid-column:3; }
.entry.right .em { grid-column:1; }
.entry.right .dc { grid-column:2; }
.entry.right .ca { grid-column:3; }

.dc {
  display:flex; flex-direction:column; align-items:center;
  padding-top:30px;
}
.dot {
  width:12px; height:12px; border-radius:50%;
  background:var(--bg);
  border:1.5px solid var(--gold-dim);
  z-index:2; flex-shrink:0;
  transition:transform .25s, border-color .25s;
}
.entry:hover .dot { transform:scale(1.6); border-color:var(--gold); }
.entry.feat .dot { width:18px; height:18px; background:var(--gold); border-color:var(--bg2); }
.dot-cat {
  width:3px; flex:1;
  margin-top:6px;
  opacity:.3;
}

/* ── CARD ── */
.card {
  background: var(--surface);
  border:1px solid var(--border);
  padding:26px;
  position:relative;
  cursor:pointer;
  transition:border-color .25s, box-shadow .25s, transform .2s;
  overflow:hidden;
}
.card:hover {
  border-color: var(--border2);
  box-shadow:0 0 40px rgba(0,0,0,.5);
  transform:translateY(-2px);
}

/* glow on hover */
.card::before {
  content:'';
  position:absolute; top:0; left:0;
  width:100%; height:2px;
  opacity:0;
  transition:opacity .3s;
}
.card:hover::before { opacity:1; }

/* side accent */
.card::after {
  content:'';
  position:absolute; top:0; left:0;
  width:3px; height:100%;
}

/* arrow connector */
.entry.left  .card { margin-right:26px; }
.entry.right .card { margin-left:26px; }
.entry.left  .card .arr { position:absolute; right:-8px; top:34px; width:0; height:0;
  border-top:7px solid transparent; border-bottom:7px solid transparent; border-left:8px solid var(--border); }
.entry.right .card .arr { position:absolute; left:-8px; top:34px; width:0; height:0;
  border-top:7px solid transparent; border-bottom:7px solid transparent; border-right:8px solid var(--border); }

/* category colors */
.c-red    ::after, .c-red    { --acc:var(--red); }
.c-amber  ::after, .c-amber  { --acc:var(--amber); }
.c-green  ::after, .c-green  { --acc:var(--green); }
.c-blue   ::after, .c-blue   { --acc:var(--blue); }
.c-purple ::after, .c-purple { --acc:var(--purple); }
.c-teal   ::after, .c-teal   { --acc:var(--teal); }
.c-rose   ::after, .c-rose   { --acc:var(--rose); }
.c-ochre  ::after, .c-ochre  { --acc:var(--ochre); }
.c-gold   ::after, .c-gold   { --acc:var(--gold); }

.card.c-red::after    { background:var(--red); }
.card.c-amber::after  { background:var(--amber); }
.card.c-green::after  { background:var(--green); }
.card.c-blue::after   { background:var(--blue); }
.card.c-purple::after { background:var(--purple); }
.card.c-teal::after   { background:var(--teal); }
.card.c-rose::after   { background:var(--rose); }
.card.c-ochre::after  { background:var(--ochre); }
.card.c-gold::after   { background:var(--gold); }

.card.c-red::before    { background:var(--red); }
.card.c-amber::before  { background:var(--amber); }
.card.c-green::before  { background:var(--green); }
.card.c-blue::before   { background:var(--blue); }
.card.c-purple::before { background:var(--purple); }
.card.c-teal::before   { background:var(--teal); }
.card.c-rose::before   { background:var(--rose); }
.card.c-ochre::before  { background:var(--ochre); }
.card.c-gold::before   { background:var(--gold); }

/* ── CARD INTERNALS ── */
.card-top {
  display:flex; align-items:flex-start; justify-content:space-between;
  gap:12px; margin-bottom:10px;
}
.card-badges { display:flex; gap:6px; flex-wrap:wrap; }
.badge {
  font-family:'DM Mono',monospace;
  font-size:9px; letter-spacing:1.5px;
  text-transform:uppercase;
  padding:2px 8px; border:1px solid;
}
.badge-period { border-color:var(--border2); color:var(--gold); background:rgba(201,168,76,0.06); }
.badge-br  { border-color:rgba(42,122,74,.35); color:#5abf80; background:rgba(42,122,74,.08); }
.badge-eu  { border-color:rgba(26,95,160,.35); color:#6aaae0; background:rgba(26,95,160,.08); }
.badge-int { border-color:rgba(138,106,26,.35); color:#c8a030; background:rgba(138,106,26,.08); }
.badge-af  { border-color:rgba(192,57,43,.35); color:#e08070; background:rgba(192,57,43,.08); }
.badge-ind { border-color:rgba(107,47,160,.35); color:#b08ae0; background:rgba(107,47,160,.08); }

.cat-icon {
  font-size:16px; flex-shrink:0;
  opacity:.7;
}

.card h2 {
  font-family:'Cormorant Garamond',serif;
  font-size:22px; font-weight:400; line-height:1.2;
  color: var(--cream);
  margin-bottom:4px;
}
.card h2 em { font-style:italic; color:var(--gold2); }

.card-period {
  font-family:'DM Mono',monospace;
  font-size:11px; color:var(--cream3);
  margin-bottom:12px; letter-spacing:.5px;
}

.card p {
  font-size:13.5px; line-height:1.7;
  color: var(--cream2);
  margin-bottom:12px;
}

/* artwork */
.arts {
  display:grid; gap:4px;
  margin:14px 0;
}
.arts.g1 { grid-template-columns:1fr; }
.arts.g2 { grid-template-columns:1fr 1fr; }
.arts.g3 { grid-template-columns:1fr 1fr 1fr; }

.art {
  position:relative; overflow:hidden;
  background: var(--bg4);
  aspect-ratio:4/3;
}
.art img {
  width:100%; height:100%; object-fit:cover;
  display:block;
  transition:transform .4s, filter .4s;
  filter:brightness(.85) contrast(1.05) sepia(.15);
}
.art:hover img { transform:scale(1.06); filter:brightness(.95) contrast(1.05) sepia(.05); }
.art-cap {
  position:absolute; bottom:0; left:0; right:0;
  background:rgba(13,11,8,.8);
  color:rgba(242,234,216,.6);
  font-size:9px; font-family:'DM Mono',monospace;
  letter-spacing:.5px;
  padding:4px 7px;
  transform:translateY(100%);
  transition:transform .2s;
}
.art:hover .art-cap { transform:translateY(0); }

/* tags */
.tags { display:flex; flex-wrap:wrap; gap:5px; margin:10px 0; }
.tag {
  font-family:'DM Mono',monospace;
  font-size:9.5px; letter-spacing:.5px;
  padding:2px 9px;
  border:1px solid var(--border);
  color:var(--cream3);
  transition:all .2s;
  cursor:default;
}
.tag:hover { border-color:var(--border2); color:var(--cream2); }
.tag.aut  { border-color:rgba(242,234,216,.2); color:var(--cream2); }
.tag.mot  { border-color:rgba(201,168,76,.25); color:var(--gold); }
.tag.conf { border-color:rgba(192,57,43,.3); color:#e08070; }
.tag.leg  { border-color:rgba(42,122,74,.3); color:#5abf80; }
.tag.inf  { border-color:rgba(26,95,160,.3); color:#6aaae0; }

/* expand */
.expand-btn {
  background:none; border:none;
  font-family:'DM Mono',monospace;
  font-size:9.5px; letter-spacing:1.5px;
  text-transform:uppercase;
  color:var(--cream3);
  cursor:pointer; display:flex; align-items:center; gap:5px;
  margin-top:12px; padding:0;
  transition:color .2s;
}
.expand-btn:hover { color:var(--gold); }
.expand-btn .ch { transition:transform .3s; display:inline-block; font-size:12px; }
.expand-btn.open .ch { transform:rotate(90deg); }

.extra {
  max-height:0; overflow:hidden;
  transition:max-height .45s ease;
}
.extra.open { max-height:1200px; }

.extra-inner {
  border-top:1px solid var(--border);
  margin-top:14px; padding-top:14px;
}

.info-block { margin-bottom:14px; }
.info-lbl {
  font-family:'DM Mono',monospace;
  font-size:9px; letter-spacing:2px;
  text-transform:uppercase;
  color:var(--cream3);
  margin-bottom:5px;
}
.info-txt { font-size:13px; color:var(--cream2); line-height:1.65; }

.pbox {
  background:rgba(192,57,43,.07);
  border-left:2px solid var(--red);
  padding:10px 13px;
  font-size:13px; color:rgba(224,128,112,.9);
  font-style:italic; margin:10px 0;
  line-height:1.6;
}
.lbox {
  background:rgba(42,122,74,.07);
  border-left:2px solid var(--green);
  padding:10px 13px;
  font-size:13px; color:rgba(90,191,128,.9);
  margin:10px 0; line-height:1.6;
}
.qbox {
  border-left:2px solid var(--gold-dim);
  padding:8px 14px;
  font-family:'Cormorant Garamond',serif;
  font-size:16px; font-style:italic;
  color:var(--cream2); margin:10px 0;
}
.qbox cite {
  display:block; font-style:normal;
  font-family:'DM Mono',monospace;
  font-size:9px; letter-spacing:1px;
  color:var(--cream3); margin-top:5px;
}

/* hidden */
.entry.hidden { display:none; }

/* ── FOOTER ── */
footer {
  background:var(--bg2);
  border-top:1px solid var(--border);
  padding:48px 56px;
  text-align:center;
}
.footer-quote {
  font-family:'Cormorant Garamond',serif;
  font-size:20px; font-style:italic; font-weight:300;
  color:var(--cream2); margin-bottom:12px;
}
.footer-attr {
  font-family:'DM Mono',monospace;
  font-size:10px; letter-spacing:1.5px;
  text-transform:uppercase;
  color:var(--cream3);
}
.footer-meta {
  margin-top:28px;
  font-family:'DM Mono',monospace;
  font-size:9px; letter-spacing:1px;
  color:rgba(138,128,112,.4);
  text-transform:uppercase;
}

@media(max-width:720px){
  header { padding:40px 20px 36px; }
  .filters-bar,.legend { padding:0 16px; }
  .tl { padding:40px 16px 60px; }
  .tl::before { left:20px; }
  .entry { grid-template-columns:40px 1fr; }
  .entry.left .ca,.entry.right .ca { grid-column:2; }
  .entry.left .dc,.entry.right .dc { grid-column:1; }
  .entry .em { display:none; }
  .entry.left .card,.entry.right .card { margin:0; }
  .entry.left .card .arr,.entry.right .card .arr { left:-7px; right:auto;
    border-right:7px solid var(--border); border-left:none; }
  .arts.g3 { grid-template-columns:1fr 1fr; }
}
</style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="header-eyebrow">Diplomacia Cultural · CACD 2026</div>
  <h1>Arte no <em>Brasil</em></h1>
  <p class="header-sub">Das pinturas rupestres ao rap periférico, da arte sacra jesuítica ao tropicalismo — todos os campos de expressão que forjaram a identidade estética de um país-continente. Música, literatura, artes plásticas, arquitetura, cinema, teatro, dança, arte popular.</p>
  <div class="header-stats">
    <div class="stat"><span class="stat-n">~12.000</span><span class="stat-d">anos de arte</span></div>
    <div class="stat"><span class="stat-n">22</span><span class="stat-d">movimentos</span></div>
    <div class="stat"><span class="stat-n">8</span><span class="stat-d">linguagens artísticas</span></div>
    <div class="stat"><span class="stat-n">3</span><span class="stat-d">matrizes culturais</span></div>
  </div>
</header>

<!-- FILTERS -->
<div class="filters-bar">
  <button class="fbtn on" onclick="fAll(this)">Todos</button>
  <button class="fbtn" onclick="fCat('musica',this)"><span class="fdot" style="background:#C9A84C"></span>Música</button>
  <button class="fbtn" onclick="fCat('literatura',this)"><span class="fdot" style="background:#6aaae0"></span>Literatura</button>
  <button class="fbtn" onclick="fCat('artes-plasticas',this)"><span class="fdot" style="background:#5abf80"></span>Artes Plásticas</button>
  <button class="fbtn" onclick="fCat('arquitetura',this)"><span class="fdot" style="background:#e08070"></span>Arquitetura</button>
  <button class="fbtn" onclick="fCat('cinema',this)"><span class="fdot" style="background:#b08ae0"></span>Cinema</button>
  <button class="fbtn" onclick="fCat('arte-sacra',this)"><span class="fdot" style="background:#c8a030"></span>Arte Sacra</button>
  <button class="fbtn" onclick="fCat('cultura-popular',this)"><span class="fdot" style="background:#c090c0"></span>Cultura Popular</button>
  <button class="fbtn" onclick="fCat('teatro-danca',this)"><span class="fdot" style="background:#70c0b0"></span>Teatro/Dança</button>
</div>

<!-- LEGEND -->
<div class="legend">
  <span class="legend-label">Origem →</span>
  <span class="ltag badge-br">● Brasileiro</span>
  <span class="ltag badge-eu">● Europeu</span>
  <span class="ltag badge-af">● Africano</span>
  <span class="ltag badge-ind">● Indígena</span>
  <span class="ltag badge-int">● Internacional</span>
  <span style="margin-left:12px" class="legend-label">Tags →</span>
  <span class="ltag tag aut">Autor</span>
  <span class="ltag tag mot">Motivação</span>
  <span class="ltag tag conf">⚡ Polêmica</span>
  <span class="ltag tag leg">↑ Legado</span>
  <span class="ltag tag inf">🌍 Influência</span>
</div>

<!-- TIMELINE -->
<div class="tl" id="tl">

<!-- ════════════ PRÉ-COLONIAL ════════════ -->
<div class="era">
  <div class="era-inner">
    <span class="era-num">c. 12.000 a.C.</span>
    <span class="era-name">Pré-Colonial · Raízes Ameríndias</span>
  </div>
</div>

<!-- ARTE RUPESTRE -->
<div class="entry left feat" data-cat="artes-plasticas cultura-popular">
  <div class="ca">
    <div class="card c-ochre"><div class="arr"></div>
      <div class="card-top">
        <div class="card-badges">
          <span class="badge badge-period">c.12.000 a.C. – séc. XVI</span>
          <span class="badge badge-ind">Indígena</span>
        </div>
        <span class="cat-icon">🗿</span>
      </div>
      <h2>Arte Rupestre &amp; <em>Arte Indígena</em></h2>
      <div class="card-period">Pré-história · Serra da Capivara (PI) · todo o território</div>
      <p>A mais antiga expressão artística do território brasileiro. Pinturas rupestres, cerâmicas, plumária, tecelagem, esculturas — um universo visual sofisticado e cosmológico, anterior e independente de qualquer influência europeia ou africana. Não é "primitivo": é outro sistema estético.</p>
      <div class="arts g2">
