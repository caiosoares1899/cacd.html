/* ── ERA CONFIG ── */
const ERA_LABELS = {colonial:"Período Colonial", imperial:"Período Imperial", republican:"República", modern:"Era Moderna", contempor:"Contemporâneo"};
const ERA_ORDER  = ["colonial","imperial","republican","modern","contempor"];
const TAG_LABELS = {colonial:"Colonial",imperial:"Imperial",republican:"República",modern:"Moderno",contempor:"Contemporâneo",acordo:"Acordo",ruptura:"Ruptura",diplomacia:"Diplomacia"};
const TAG_CLS    = {colonial:"tc",imperial:"ti",republican:"tr",modern:"tm",contempor:"tk",acordo:"ta",ruptura:"tx",diplomacia:"td"};

/* ── STATE ── */
let activeEra = "all", activeSearch = "", activeEv = null;

/* ── ELEMENTS ── */
const sidebar    = document.getElementById("sidebar");
const timelineEl = document.getElementById("timelineEl");
const overlay    = document.getElementById("detailOverlay");
const dTitle     = document.getElementById("dTitle");
const dMeta      = document.getElementById("dMeta");
const dSub       = document.getElementById("dSub");
const dMetaRow   = document.getElementById("dMetaRow");
const dTabs      = document.getElementById("dTabs");
const dBody      = document.getElementById("dBody");
const quickBar   = document.getElementById("quickBar");

/* ── RENDER ── */
function tagHtml(t) { return `<span class="tag ${TAG_CLS[t]||'tc'}">${TAG_LABELS[t]||t}</span>`; }

function visible(ev) {
  const eraOk = activeEra === "all" || ev.era === activeEra;
  const search = activeSearch.toLowerCase();
  const searchOk = !search || ev.title.toLowerCase().includes(search) || ev.year.includes(search) || ev.sub.toLowerCase().includes(search);
  return eraOk && searchOk;
}

function render() {
  timelineEl.innerHTML = "";
  sidebar.innerHTML = "";
  quickBar.innerHTML = "";

  let currentEra = null;
  let side = 0; // alternating

  EVENTS.forEach(ev => {
    if (!visible(ev)) return;

    // Quick bar pill
    const qp = document.createElement("button");
    qp.className = "qpill";
    qp.textContent = ev.year + " · " + ev.title.slice(0,28) + (ev.title.length>28?"…":"");
    qp.onclick = () => openDetail(ev);
    quickBar.appendChild(qp);

    // Sidebar section header
    if (ev.era !== currentEra) {
      currentEra = ev.era;
      const sh = document.createElement("div");
      sh.className = "sidebar-section";
      sh.innerHTML = `<div class="section-era">${ERA_LABELS[ev.era]}</div>`;
      sidebar.appendChild(sh);
    }

    // Sidebar nav item
    const ni = document.createElement("div");
    ni.className = "nav-item" + (activeEv === ev.id ? " active" : "");
    ni.id = "nav-" + ev.id;
    ni.innerHTML = `
      <div class="nav-dot" style="background:${ev.dot}"></div>
      <div class="nav-info">
        <div class="nav-year">${ev.year}</div>
        <div class="nav-title">${ev.title}</div>
        <span class="nav-tag tag ${TAG_CLS[ev.tags[0]]||'tc'}">${TAG_LABELS[ev.tags[0]]||ev.tags[0]}</span>
      </div>`;
    ni.onclick = () => { openDetail(ev); scrollToCard(ev.id); };
    sidebar.appendChild(ni);

    // Timeline row (alternating, like Militares)
    const row = document.createElement("div");
    row.className = "ev-row visible";
    row.id = "row-" + ev.id;

    const cardHtml = `
      <div class="ev-card" data-id="${ev.id}">
        <div class="ev-card-year" style="color:${ev.dot}">${ev.year}</div>
        <div class="ev-card-tags">${ev.tags.map(tagHtml).join("")}</div>
        <div class="ev-card-title">${ev.title}</div>
        <div class="ev-card-sub">${ev.sub}</div>
      </div>`;

    if (side % 2 === 0) {
      row.innerHTML = `
        <div class="ev-left">${cardHtml}</div>
        <div class="ev-center"><div class="ev-dot" style="background:${ev.dot}" data-id="${ev.id}"></div></div>
        <div class="ev-right ev-empty"></div>`;
    } else {
      row.innerHTML = `
        <div class="ev-left ev-empty"></div>
        <div class="ev-center"><div class="ev-dot" style="background:${ev.dot}" data-id="${ev.id}"></div></div>
        <div class="ev-right">${cardHtml}</div>`;
    }

    row.querySelectorAll(".ev-card, .ev-dot").forEach(el => {
      el.onclick = () => openDetail(ev);
    });

    timelineEl.appendChild(row);
    side++;
  });
}

function scrollToCard(id) {
  const el = document.getElementById("row-" + id);
  el?.scrollIntoView({ behavior: "smooth", block: "center" });
}

/* ── DETAIL DRAWER ── */
function openDetail(ev) {
  activeEv = ev.id;
  document.querySelectorAll(".nav-item").forEach(n => n.classList.remove("active"));
  const ni = document.getElementById("nav-" + ev.id);
  if (ni) ni.classList.add("active");

  // Header
  dMeta.textContent = ev.year + "  ·  " + ERA_LABELS[ev.era];
  dTitle.textContent = ev.title;
  dSub.textContent = ev.sub;

  // 3-col meta row
  if (ev.meta && ev.meta.length) {
    dMetaRow.innerHTML = ev.meta.map(m =>
      `<div class="meta-col"><div class="meta-col-label">${m.lbl}</div><div class="meta-col-content">${m.val}</div></div>`
    ).join("");
    dMetaRow.style.display = "grid";
  } else {
    dMetaRow.style.display = "none";
  }

  // Build tabs
  const tabNames = ["Contexto RI", "Atores", "Impacto"];
  const extraTabs = Object.keys(ev.tabs).filter(t => !tabNames.includes(t));
  const allTabs = [...tabNames, ...extraTabs];

  dTabs.innerHTML = allTabs.map((t,i) =>
    `<div class="dtab${i===0?" active":""}" data-tab="${i}">${t}</div>`
  ).join("");

  dBody.innerHTML = allTabs.map((tabName, i) => {
    let html = `<div class="tab-panel${i===0?" active":""}" data-panel="${i}">`;

    if (tabName === "Atores") {
      if (ev.actors && ev.actors.length) {
        html += `<div class="tp-section"><div class="tp-label">Atores principais</div>
          <div class="tp-actors">${ev.actors.map(a => `<div class="actor-chip"><div class="actor-name">${a.name}</div><div class="actor-role">${a.role}</div></div>`).join("")}</div></div>`;
      } else {
        html += `<div class="tp-section"><div class="tp-text" style="color:var(--muted)">Não especificado.</div></div>`;
      }
    } else {
      // Stats
      if (ev.stats && i === 0) {
        html += `<div class="tp-grid">${ev.stats.map(s => `<div class="tp-stat"><div class="tp-stat-val">${s.val}</div><div class="tp-stat-lbl">${s.lbl}</div></div>`).join("")}</div>`;
      }
      // Sections
      const sections = ev.tabs[tabName] || [];
      sections.forEach(s => {
        if (s.lbl) html += `<div class="tp-section"><div class="tp-label">${s.lbl}</div><div class="tp-text">${s.txt}</div></div>`;
        else if (s.txt) html += `<div class="tp-section"><div class="tp-text">${s.txt}</div></div>`;
      });
      // Quote
      if (ev.quote && tabName === "Impacto") {
        html += `<div class="quote-block"><div class="quote-text">"${ev.quote.txt}"</div><div class="quote-author">— ${ev.quote.author}</div></div>`;
      }
    }

    html += `</div>`;
    return html;
  }).join("");

  dTabs.querySelectorAll(".dtab").forEach(tab => {
    tab.onclick = () => {
      const idx = tab.dataset.tab;
      dTabs.querySelectorAll(".dtab").forEach(t => t.classList.remove("active"));
      dBody.querySelectorAll(".tab-panel").forEach(p => p.classList.remove("active"));
      tab.classList.add("active");
      dBody.querySelector(`[data-panel="${idx}"]`)?.classList.add("active");
    };
  });

  overlay.classList.add("open");
}

function closeDetail() {
  overlay.classList.remove("open");
  activeEv = null;
  document.querySelectorAll(".nav-item").forEach(n => n.classList.remove("active"));
}

document.getElementById("drawerClose").onclick = closeDetail;
overlay.onclick = e => { if (e.target === overlay) closeDetail(); };

/* ── FILTERS ── */
document.querySelectorAll("[data-era]").forEach(btn => {
  btn.onclick = () => {
    document.querySelectorAll("[data-era]").forEach(b => b.classList.remove("on"));
    btn.classList.add("on");
    activeEra = btn.dataset.era;
    render();
  };
});

document.getElementById("searchInput").oninput = e => {
  activeSearch = e.target.value;
  render();
};

/* ── INIT ── */
render();
</script>
