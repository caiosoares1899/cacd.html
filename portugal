<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Brasil – Portugal · Relações Internacionais · CACD</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=IBM+Plex+Mono:wght@300;400;600&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
<style>
/* ── TOKENS (mesclagem PEB dark + Militares gold) ── */
:root {
  --bg:        #0d1117;
  --bg2:       #090d12;
  --panel:     #13191f;
  --panel2:    #171e26;
  --border:    #2a3240;
  --gold:      #c9a84c;
  --gold-bright: #e8c97a;
  --gold-dim:  rgba(201,168,76,0.12);
  --gold-line: rgba(201,168,76,0.3);
  --text:      #f0ece2;
  --muted:     #7a8494;
  --red:       #c0392b;
  --green:     #5f9a6a;
  --blue:      #4a7cb5;
  --teal:      #3a8c84;
  --purple:    #8e5ea0;
  --orange:    #c47a35;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  font-family: "IBM Plex Mono", monospace;
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── HERO (do Militares) ── */
.hero {
  background: linear-gradient(180deg, #050709 0%, #0d1117 70%, transparent 100%);
  padding: 4.5rem 2rem 3.5rem;
  text-align: center;
  position: relative;
  border-bottom: 1px solid var(--gold-line);
}
.hero::before {
  content: '';
  position: absolute;
  bottom: -1px; left: 50%;
  transform: translateX(-50%);
  width: 80px; height: 2px;
  background: var(--gold);
}
.hero-label {
  font-family: "IBM Plex Mono", monospace;
  font-size: .58rem;
  letter-spacing: .32em;
  color: var(--gold);
  text-transform: uppercase;
  margin-bottom: 1.4rem;
}
.hero-flags {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  margin-bottom: 1.2rem;
}
.hflag {
  width: 54px; height: 36px; border-radius: 3px;
  border: 1px solid rgba(255,255,255,0.15);
  overflow: hidden; position: relative;
  flex-shrink: 0;
}
.hflag svg { width: 100%; height: 100%; display: block; }
.hero-sep { color: var(--gold); font-size: 1.2rem; opacity: .7; }
.hero h1 {
  font-family: "Playfair Display", serif;
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 900;
  line-height: 1.1;
  margin-bottom: .5rem;
}
.hero h1 em { color: var(--gold); font-style: italic; }
.hero-sub {
  font-family: "Crimson Pro", serif;
  font-style: italic;
  font-size: clamp(.9rem, 2vw, 1.1rem);
  color: var(--muted);
  margin-bottom: 2.2rem;
}

/* era legend dots */
.era-legend {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18px;
  flex-wrap: wrap;
}
.era-legend-item {
  display: flex; align-items: center; gap: 6px;
  font-size: .5rem; letter-spacing: .08em;
  text-transform: uppercase; color: var(--muted);
}
.era-legend-dot {
  width: 8px; height: 8px; border-radius: 50%;
}

/* ── FILTER BAR (do Militares) ── */
.filter-bar {
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  padding: 12px 20px;
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  position: sticky;
  top: 0;
  z-index: 100;
}
.filter-lbl {
  font-size: .46rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--muted);
  margin-right: 4px;
}
.fbtn {
  font-family: "IBM Plex Mono", monospace;
  font-size: .5rem;
  padding: 5px 14px;
  letter-spacing: .09em;
  text-transform: uppercase;
  cursor: pointer;
  border: 1.5px solid var(--border);
  background: transparent;
  color: var(--muted);
  border-radius: 2px;
  transition: all .15s;
}
.fbtn:hover, .fbtn.on {
  border-color: var(--gold);
  color: var(--gold);
  background: var(--gold-dim);
}
.filter-spacer { flex: 1; }
.search-box {
  background: var(--panel);
  border: 1px solid var(--border);
  color: var(--text);
  font-family: "IBM Plex Mono", monospace;
  font-size: .52rem;
  padding: 5px 12px;
  border-radius: 2px;
  outline: none;
  width: 180px;
}
.search-box:focus { border-color: var(--gold); }
.search-box::placeholder { color: var(--muted); }

/* ── MAIN SPLIT (do PEB) ── */
.workspace {
  display: grid;
  grid-template-columns: 270px 1fr;
  min-height: calc(100vh - 160px);
}

/* ── SIDEBAR (do PEB) ── */
.sidebar {
  background: var(--bg2);
  border-right: 1px solid var(--border);
  overflow-y: auto;
  position: sticky;
  top: 50px;
  height: calc(100vh - 50px);
}
.sidebar-section {
  border-bottom: 1px solid var(--border);
}
.section-era {
  padding: 10px 16px 6px;
  font-size: .58rem;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--gold);
  display: flex;
  align-items: center;
  gap: 8px;
}
.section-era::after {
  content: ''; flex: 1; height: 1px;
  background: var(--gold-line);
}
.nav-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 11px 16px;
  cursor: pointer;
  border-left: 2px solid transparent;
  transition: all .15s;
}
.nav-item:hover { background: var(--gold-dim); }
.nav-item.active {
  background: var(--gold-dim);
  border-left-color: var(--gold);
}
.nav-dot {
  width: 8px; height: 8px;
  border-radius: 50%; margin-top: 5px; flex-shrink: 0;
}
.nav-info { flex: 1; min-width: 0; }
.nav-year {
  font-size: .62rem; font-weight: 600;
  color: var(--muted); letter-spacing: .04em;
}
.nav-item.active .nav-year { color: var(--gold); }
.nav-title {
  font-size: .67rem; color: var(--text);
  line-height: 1.35; margin-top: 2px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.nav-tag {
  font-size: .5rem; padding: 2px 7px; border-radius: 2px;
  text-transform: uppercase; letter-spacing: .06em;
  margin-top: 4px; display: inline-block;
}

/* ── CONTENT AREA ── */
.content {
  overflow-y: auto;
}

/* ── TIMELINE CENTRAL (do Militares) ── */
.timeline-wrap {
  padding: 50px 48px 100px;
  position: relative;
}
.tl-line {
  position: absolute;
  left: 50%; top: 0; bottom: 0;
  width: 2px;
  transform: translateX(-50%);
  background: linear-gradient(180deg, transparent, var(--border) 5%, var(--border) 95%, transparent);
}

/* era divider */
.era-block {
  position: relative;
  text-align: center;
  margin: 48px 0 32px;
  z-index: 2;
}
.era-block-label {
  display: inline-block;
  font-size: .52rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  padding: 6px 20px;
  border: 1px solid var(--gold-line);
  background: var(--bg);
  color: var(--gold);
  position: relative;
}

/* event row — alternating sides (do Militares) */
.ev-row {
  display: grid;
  grid-template-columns: 1fr 40px 1fr;
  gap: 0;
  align-items: start;
  margin-bottom: 32px;
  position: relative;
  opacity: 0;
  transform: translateY(16px);
  transition: opacity .4s, transform .4s;
}
.ev-row.visible { opacity: 1; transform: translateY(0); }
.ev-row.hidden { display: none; }

.ev-left, .ev-right { padding: 0; }
.ev-left { text-align: right; padding-right: 28px; }
.ev-right { text-align: left; padding-left: 28px; }
.ev-empty { /* spacer */ }

/* center column dot */
.ev-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 14px;
  position: relative;
  z-index: 2;
}
.ev-dot {
  width: 14px; height: 14px;
  border-radius: 50%;
  border: 2px solid var(--bg);
  flex-shrink: 0;
  cursor: pointer;
  transition: transform .2s;
}
.ev-dot:hover { transform: scale(1.3); }

/* card (PEB card style) */
.ev-card {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: 14px 16px;
  cursor: pointer;
  transition: border-color .2s, background .2s;
  text-align: left;
}
.ev-card:hover { border-color: var(--gold); background: var(--panel2); }
.ev-card.active { border-color: var(--gold); background: var(--panel2); }
.ev-card-year {
  font-family: "IBM Plex Mono", monospace;
  font-size: .56rem; font-weight: 600;
  letter-spacing: .06em;
  margin-bottom: 5px;
}
.ev-card-tags { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 7px; }
.ev-card-title {
  font-family: "Playfair Display", serif;
  font-size: .92rem; font-weight: 700;
  line-height: 1.3; margin-bottom: 5px;
}
.ev-card-sub {
  font-family: "Crimson Pro", serif;
  font-size: .82rem; color: var(--muted); line-height: 1.5;
}

/* right-side card: reversed tags alignment */
.ev-right .ev-card-tags { justify-content: flex-start; }
.ev-left .ev-card-tags { justify-content: flex-end; }
.ev-left .ev-card { text-align: right; }

/* ── DETAIL PANEL (do PEB) ── */
.detail-overlay {
  display: none;
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(5,7,9,0.7);
  z-index: 200;
  align-items: flex-end;
}
.detail-overlay.open { display: flex; }
.detail-drawer {
  width: 100%;
  max-height: 75vh;
  background: var(--panel);
  border-top: 2px solid var(--gold);
  display: flex;
  flex-direction: column;
  animation: slideUp .25s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}
.drawer-header {
  padding: 16px 24px 12px;
  border-bottom: 1px solid var(--border);
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 16px;
  align-items: start;
  flex-shrink: 0;
}
.drawer-meta {
  font-size: .48rem;
  color: var(--gold);
  letter-spacing: .1em;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.drawer-title {
  font-family: "Playfair Display", serif;
  font-size: clamp(1.2rem, 3vw, 1.8rem);
  font-weight: 900;
  line-height: 1.2;
  margin-bottom: 6px;
}
.drawer-sub {
  font-family: "Crimson Pro", serif;
  font-style: italic;
  font-size: .9rem;
  color: var(--muted);
  line-height: 1.5;
}
.drawer-close {
  background: var(--bg2);
  border: 1px solid var(--border);
  color: var(--muted);
  width: 32px; height: 32px;
  border-radius: 2px;
  cursor: pointer;
  font-size: .8rem;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: border-color .15s;
}
.drawer-close:hover { border-color: var(--gold); color: var(--gold); }

/* three-column meta row (do PEB) */
.drawer-meta-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.meta-col {
  padding: 12px 20px;
  border-right: 1px solid var(--border);
}
.meta-col:last-child { border-right: none; }
.meta-col-label {
  font-size: .44rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 6px;
}
.meta-col-content {
  font-family: "Crimson Pro", serif;
  font-size: .84rem;
  color: var(--text);
  line-height: 1.6;
}

/* tabs (do PEB) */
.drawer-tabs {
  display: flex;
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
  scrollbar-width: none;
  flex-shrink: 0;
}
.drawer-tabs::-webkit-scrollbar { display: none; }
.dtab {
  font-family: "IBM Plex Mono", monospace;
  font-size: .5rem;
  padding: 10px 16px;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--muted);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  white-space: nowrap;
  transition: all .15s;
}
.dtab:hover { color: var(--text); }
.dtab.active { color: var(--gold); border-bottom-color: var(--gold); }

.drawer-body {
  overflow-y: auto;
  flex: 1;
}
.tab-panel { display: none; padding: 20px 24px 32px; }
.tab-panel.active { display: block; }

/* content widgets */
.tp-section { margin-bottom: 20px; }
.tp-label {
  font-size: .46rem;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 8px;
}
.tp-text {
  font-family: "Crimson Pro", serif;
  font-size: .9rem;
  line-height: 1.75;
  color: var(--text);
}
.tp-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
  gap: 10px;
  margin-bottom: 20px;
}
.tp-stat {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: 12px 14px;
}
.tp-stat-val {
  font-family: "Playfair Display", serif;
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--gold);
  line-height: 1;
}
.tp-stat-lbl {
  font-size: .44rem;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .08em;
  margin-top: 3px;
}
.tp-list { list-style: none; }
.tp-list li {
  font-family: "Crimson Pro", serif;
  font-size: .88rem;
  color: var(--text);
  padding: 5px 0;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: flex-start; gap: 8px; line-height: 1.5;
}
.tp-list li::before { content: '›'; color: var(--gold); flex-shrink: 0; }
.tp-actors { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; }
.actor-chip {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 2px;
  padding: 7px 12px;
}
.actor-name { font-size: .56rem; color: var(--text); font-weight: 600; }
.actor-role { font-size: .46rem; color: var(--muted); margin-top: 2px; }
.quote-block {
  background: var(--bg);
  border-left: 3px solid var(--gold);
  padding: 14px 18px;
  margin: 14px 0;
  border-radius: 0 3px 3px 0;
}
.quote-text {
  font-family: "Crimson Pro", serif;
  font-style: italic;
  font-size: .95rem;
  color: var(--text);
  line-height: 1.65;
}
.quote-author {
  font-size: .46rem;
  color: var(--muted);
  letter-spacing: .08em;
  text-transform: uppercase;
  margin-top: 8px;
}

/* tags */
.tag {
  font-size: .44rem;
  padding: 2px 7px;
  border-radius: 2px;
  text-transform: uppercase;
  letter-spacing: .06em;
}
.tc { background:rgba(201,168,76,.10);  color:var(--gold);    border:1px solid rgba(201,168,76,.3);  }
.ti { background:rgba(142,94,160,.12);  color:var(--purple);  border:1px solid rgba(142,94,160,.3);  }
.tr { background:rgba(74,124,181,.12);  color:var(--blue);    border:1px solid rgba(74,124,181,.3);   }
.tm { background:rgba(58,140,132,.12);  color:var(--teal);    border:1px solid rgba(58,140,132,.3);   }
.tk { background:rgba(201,168,76,.14);  color:var(--gold-bright); border:1px solid rgba(201,168,76,.35); }
.ta { background:rgba(95,154,106,.12);  color:var(--green);   border:1px solid rgba(95,154,106,.3);   }
.tx { background:rgba(192,57,43,.12);   color:var(--red);     border:1px solid rgba(192,57,43,.3);    }
.td { background:rgba(74,124,181,.12);  color:var(--blue);    border:1px solid rgba(74,124,181,.3);   }

/* footer quick-access (do PEB) */
.quick-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--bg2);
  border-top: 1px solid var(--border);
  padding: 7px 20px;
  display: flex;
  gap: 6px;
  overflow-x: auto;
  scrollbar-width: none;
  z-index: 150;
}
.quick-bar::-webkit-scrollbar { display: none; }
.qpill {
  font-size: .44rem;
  padding: 4px 10px;
  border: 1px solid var(--border);
  border-radius: 2px;
  color: var(--muted);
  white-space: nowrap;
  cursor: pointer;
  transition: all .15s;
  font-family: "IBM Plex Mono", monospace;
  letter-spacing: .06em;
  text-transform: uppercase;
  background: transparent;
}
.qpill:hover { border-color: var(--gold); color: var(--gold); }

/* scrollbar */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: var(--bg2); }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--muted); }

/* mobile */
@media (max-width: 768px) {
  .workspace { grid-template-columns: 1fr; }
  .sidebar { display: none; }
  .timeline-wrap { padding: 30px 16px 80px; }
  .ev-row { grid-template-columns: 20px 1fr; }
  .ev-left { display: none; }
  .ev-right { padding-left: 14px; grid-column: 2; }
  .ev-center { grid-column: 1; }
  .tl-line { left: 20px; transform: none; }
  .drawer-meta-row { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<!-- ── HERO ── -->
<section class="hero">
  <div class="hero-label">Linha do Tempo · CACD 2026</div>
  <div class="hero-flags">
    <div class="hflag">
      <svg viewBox="0 0 54 36" xmlns="http://www.w3.org/2000/svg">
        <rect width="54" height="36" fill="#009c3b"/>
        <polygon points="27,3 51,18 27,33 3,18" fill="#FFDF00"/>
        <circle cx="27" cy="18" r="8.5" fill="#002776"/>
        <path d="M19,16 Q27,13.5 35,16" stroke="white" stroke-width="1.1" fill="none" stroke-linecap="round"/>
      </svg>
    </div>
    <span class="hero-sep">↔</span>
    <div class="hflag">
      <svg viewBox="0 0 54 36" xmlns="http://www.w3.org/2000/svg">
        <rect width="54" height="36" fill="#d52b1e"/>
        <rect width="22" height="36" fill="#006600"/>
        <ellipse cx="22" cy="18" rx="7.5" ry="9" fill="#ffd700" stroke="#003399" stroke-width="0.7"/>
        <ellipse cx="22" cy="18" rx="5.5" ry="6.5" fill="none" stroke="#003399" stroke-width="0.7"/>
        <line x1="14.5" y1="18" x2="29.5" y2="18" stroke="#003399" stroke-width="0.7"/>
        <line x1="22" y1="9" x2="22" y2="27" stroke="#003399" stroke-width="0.7"/>
      </svg>
    </div>
  </div>
  <h1>Brasil – <em>Portugal</em></h1>
  <p class="hero-sub">Relações Internacionais · 1500 – hoje · Da colônia à parceria estratégica</p>
  <div class="era-legend">
    <div class="era-legend-item"><div class="era-legend-dot" style="background:#c9a84c"></div>Colonial</div>
    <div class="era-legend-item"><div class="era-legend-dot" style="background:#8e5ea0"></div>Imperial</div>
    <div class="era-legend-item"><div class="era-legend-dot" style="background:#4a7cb5"></div>República</div>
    <div class="era-legend-item"><div class="era-legend-dot" style="background:#3a8c84"></div>Moderno</div>
    <div class="era-legend-item"><div class="era-legend-dot" style="background:#e8c97a"></div>Contemporâneo</div>
    <div class="era-legend-item"><div class="era-legend-dot" style="background:#5f9a6a"></div>Acordo</div>
    <div class="era-legend-item"><div class="era-legend-dot" style="background:#c0392b"></div>Ruptura</div>
  </div>
</section>

<!-- ── FILTER BAR ── -->
<div class="filter-bar">
  <span class="filter-lbl">Era:</span>
  <button class="fbtn on" data-era="all">Todas</button>
  <button class="fbtn" data-era="colonial">Colonial</button>
  <button class="fbtn" data-era="imperial">Imperial</button>
  <button class="fbtn" data-era="republican">República</button>
  <button class="fbtn" data-era="modern">Moderno</button>
  <button class="fbtn" data-era="contempor">Contemporâneo</button>
  <div class="filter-spacer"></div>
  <input class="search-box" id="searchInput" type="text" placeholder="buscar evento…">
</div>

<!-- ── WORKSPACE ── -->
<div class="workspace">

  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar"></aside>

  <!-- TIMELINE -->
  <div class="content">
    <div class="timeline-wrap">
      <div class="tl-line"></div>
      <div id="timelineEl"></div>
    </div>
  </div>

</div>

<!-- ── DETAIL DRAWER (do PEB) ── -->
<div class="detail-overlay" id="detailOverlay">
  <div class="detail-drawer" id="detailDrawer">
    <div class="drawer-header">
      <div>
        <div class="drawer-meta" id="dMeta"></div>
        <div class="drawer-title" id="dTitle"></div>
